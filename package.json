{
  "name": "TagStrip",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/tagstrip.cjs",
  "module": "./dist/tagstrip.js",
  "browser": "./dist/tagstrip.umd.js",
  "exports": {
    ".": {
      "import": "./dist/tagstrip.js",
      "require": "./dist/tagstrip.cjs"
    }
  },
  "scripts": {
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "serve": "node serve.js",
    "serve:https": "node generate-ssl.js && node serve.js",
    "demo": "npm run build && node generate-ssl.js && node serve.js",
    "dev": "node generate-ssl.js && vite --config vite.dev.config.js"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^3.0.0",
    "concurrently": "^9.2.1",
    "jsdom": "^29.0.2",
    "sharp": "^0.34.5",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
